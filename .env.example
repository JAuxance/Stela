# Google OAuth — Desktop app client (see README "Configuration Google Cloud").
# Copy this file to ".env" and fill in your own values.
# These are NOT truly secret for a desktop app: PKCE (S256) protects the token
# exchange. Still, .env is git-ignored so they stay out of the repo.

VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-your_desktop_client_secret
